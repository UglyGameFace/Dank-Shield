# ============================================================
# Dank Shield Bot Environment Example
# ------------------------------------------------------------
# Public production defaults are shown here.
# Never commit real tokens, service-role keys, API secrets, or customer data.
# ============================================================

# ==============================
# Deployment / Public Safety
# ==============================
# local | beta | public | production
DEPLOYMENT_ENV=production
STONEY_DEPLOYMENT_MODE=production
STONEY_PUBLIC_MODE=true
STONEY_PRODUCTION_MODE=true

# Public keeps the slash-command surface small and grouped.
# Do NOT use full/dev in public production; those expose legacy/dev commands.
STONEY_COMMAND_PROFILE=public
STONEY_COMMAND_LOG_STYLE=compact
STONEY_STARTUP_LOG_STYLE=compact

# Public bots should rely on per-guild DB config, not one hardcoded server.
# For production, leave GUILD_ID blank unless you are intentionally doing a one-server beta sync.
STONEY_GUILD_CONFIG_TABLE=guild_configs
STONEY_GUILD_CONFIG_CACHE_TTL_SECONDS=60
GUILD_ID=

# Prevent duplicate slash commands in public production.
# Global commands are the public source of truth. Beta guild command sync is for local/beta testing only.
STONEY_SYNC_BETA_GUILD_COMMANDS=false
CLEAR_GLOBAL_COMMANDS_ON_BOOT=false
STONEY_DANGEROUS_CLEAR_ALL_GLOBAL_COMMANDS_ON_BOOT=false
STONEY_COMMAND_MODULES=
STONEY_COMMAND_MODULES_EXTRA=
STONEY_COMMAND_MODULES_SKIP=

# At larger scale, keep this on before rollout to many servers.
# Discord still controls actual shard allocation / gateway behavior.
DISCORD_AUTO_SHARD=true
STONEY_EXPECTED_PUBLIC_GUILDS=100

# Runtime job protection for startup syncs, metrics, ticket automation, etc.
STONEY_RUNTIME_JOBS_MAX_CONCURRENT=8
STONEY_STARTUP_MAX_GUILDS=50

# ==============================
# Legal / Trust / Public Bot Pages
# ==============================
# These URLs should be public before inviting strangers/paid customers.
# They help admins understand what the bot stores and how to request deletion.
PUBLIC_BOT_TERMS_URL=
PUBLIC_BOT_PRIVACY_URL=
PUBLIC_BOT_SUPPORT_URL=
PUBLIC_BOT_DATA_REQUEST_URL=

# Recommended policy defaults. The bot should avoid keeping unnecessary data forever.
TICKET_TRANSCRIPT_RETENTION_DAYS=90
MODLOG_RETENTION_DAYS=180
METRICS_RETENTION_DAYS=180

# If your community is age-restricted or cannabis/adult-themed, use this only as a safety gate.
# Do not use the bot to facilitate illegal sales, shipping, sourcing, evasion, or regulated transactions.
COMMUNITY_AGE_GATE_REQUIRED=false
COMMUNITY_MINIMUM_AGE=18

# ==============================
# Core Discord
# ==============================
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=

# ==============================
# Supabase
# ==============================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URL is optional, but required for automatic schema bootstrap/migrations.
# Use only a secure pooled/direct connection string from Supabase or your Postgres host.
SUPABASE_DB_URL=
DATABASE_URL=

# ==============================
# Verification / Website
# ==============================
VERIFY_SITE_URL=
BOT_ACTIONS_API_URL=

# ==============================
# Secure Structured Bot API
# ==============================
# Shared secret required by the structured bot API for all non-health routes.
# Use a strong random value with at least 32 characters.
# Send this as either:
#   Authorization: Bearer <secret>
#   X-API-Key: <secret>
#   X-Stoney-Internal-Auth: <secret>
BOT_API_SHARED_SECRET=

# Hosted public deployments may bind to 0.0.0.0 only when auth is required and the port is protected by your host/firewall/proxy.
BOT_API_BIND_HOST=0.0.0.0
BOT_API_PORT=8081
BOT_API_REQUIRE_AUTH=true
BOT_API_ALLOW_INSECURE=false

# Disable the old unauthenticated legacy API in public mode.
LEGACY_BOT_ACTIONS_API_ENABLED=false

# ==============================
# Ticket / Transcript System
# ==============================
# Public production should save these per guild through /dank setup.
# Leave global IDs blank so one server's channels/roles do not leak into another server.
TICKET_CATEGORY_ID=
TICKET_PREFIX=ticket
AUTO_DELETE_TICKET_SECONDS=0
TRANSCRIPTS_CHANNEL_ID=
TRANSCRIPT_PANEL_NAME=Support
SINGLE_PANEL_MODE=true
JOIN_LOG_CHANNEL_ID=0

# ==============================
# Verification Channels / Timers
# ==============================
VERIFY_CHANNEL_ID=
VC_VERIFY_CHANNEL_ID=
VC_VERIFY_QUEUE_CHANNEL_ID=
TOKEN_TTL_MINUTES=240
VC_REQUEST_TTL_MINUTES=240
VERIFY_KICK_HOURS=24
VC_REQUEST_COOLDOWN_SECONDS=60

# ==============================
# Roles
# ==============================
UNVERIFIED_ROLE_ID=
VERIFIED_ROLE_ID=
RESIDENT_ROLE_ID=
STONER_ROLE_ID=
DRUNKEN_ROLE_ID=
STAFF_ROLE_ID=
VC_STAFF_ROLE_ID=

# ==============================
# Moderation / Logging
# ==============================
MOD_TIMEOUT_MINUTES=60
MOD_ACTION_AUDIT_LOOKBACK_SECONDS=20
MODLOG_CHANNEL_ID=
RAIDLOG_CHANNEL_ID=
FORCE_VERIFY_LOG_CHANNEL_ID=

# ==============================
# Raid Detection
# ==============================
RAID_WINDOW_SECONDS=60
RAID_JOIN_THRESHOLD=6
RAID_LOCK_MINUTES=15
RAID_MASS_ROLE_STRIP=true

# ==============================
# Alt Detection
# ==============================
ALT_NEW_ACCOUNT_DAYS=7
ALT_CLUSTER_WINDOW_MINUTES=30
ALT_CLUSTER_MIN_GROUP=3

# ==============================
# Visual / Optional Roles
# ==============================
ENABLE_OPTIONAL_ROLE_PROMPT=true
OPTIONAL_ROLE_AUTO_CLOSE_SECONDS=0
VERIFY_EMBED_THUMBNAIL_URL=
ALLOW_USER_VERIFYLINK=false
VERIFY_TOKEN_TABLE=verification_tokens
TOKEN_TABLE=verification_tokens

# Dank Shield branding
BOT_DISPLAY_NAME=Dank Shield
VERIFY_UI_TITLE=Dank Shield Verification
DANK_SHIELD_TAGLINE_SHORT=Good vibes in. Bad actors out.
DANK_SHIELD_TAGLINE_LONG=Verification, tickets, and server protection without snuffing out the vibe.

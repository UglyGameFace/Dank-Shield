# ============================================================
# Stoney Verify Bot Environment Example
# ------------------------------------------------------------
# Public-safe defaults are shown here.
# Never commit real tokens, service-role keys, API secrets, or customer data.
# ============================================================

# ==============================
# Deployment / Public Safety
# ==============================
# local | beta | public
DEPLOYMENT_ENV=public
DEPLOYMENT_PROFILE=public
PUBLIC_STARTUP_PROFILE=public

# public keeps the slash-command surface small and grouped.
# full is dev-only because Discord has a 100 global command limit.
STONEY_COMMAND_PROFILE=public

# Public bots should rely on per-guild DB config, not one hardcoded server.
# GUILD_ID and global Discord IDs may be used for local/beta testing only.
# In public production, guild-specific channels/roles/categories must resolve from DB guild config first.
STONEY_GUILD_CONFIG_TABLE=guild_configs
STONEY_GUILD_CONFIG_CACHE_TTL_SECONDS=60

# At larger scale, turn this on before rollout to many servers.
DISCORD_AUTO_SHARD=true

# Runtime job protection for startup syncs, metrics, ticket automation, etc.
STONEY_RUNTIME_JOBS_MAX_CONCURRENT=8
STONEY_STARTUP_GUILD_TASK_TIMEOUT_SECONDS=45
STONEY_STARTUP_GUILD_TASK_RETRIES=5

# ==============================
# Legal / Trust / Public Bot Pages
# ==============================
# These URLs should be public before inviting strangers/paid customers.
# They help admins understand what the bot stores and how to request deletion.
PUBLIC_BOT_TERMS_URL=
PUBLIC_BOT_PRIVACY_URL=
PUBLIC_BOT_SUPPORT_URL=
PUBLIC_BOT_DATA_REQUEST_URL=

# Recommended policy defaults. The bot should avoid keeping unnecessary data forever.
TICKET_TRANSCRIPT_RETENTION_DAYS=90
MODLOG_RETENTION_DAYS=180
METRICS_RETENTION_DAYS=180

# If your community is age-restricted or cannabis/adult-themed, use this only as a safety gate.
# Do not use the bot to facilitate illegal sales, shipping, sourcing, evasion, or regulated transactions.
COMMUNITY_AGE_GATE_REQUIRED=false
COMMUNITY_MINIMUM_AGE=18

# ==============================
# Core Discord
# ==============================
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=
GUILD_ID=0

# ==============================
# Supabase
# ==============================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================
# Verification / Website
# ==============================
VERIFY_SITE_URL=
BOT_ACTIONS_API_URL=

# ==============================
# Secure Structured Bot API
# ==============================
# /health is public and cheap.
# All mutation routes must require BOT_API_SHARED_SECRET when BOT_API_REQUIRE_AUTH=true.
# Public hosted containers normally need BOT_API_BIND_HOST=0.0.0.0 so platform health checks can reach /health.
BOT_API_SHARED_SECRET=
BOT_API_BIND_HOST=0.0.0.0
BOT_API_PORT=8081
BOT_API_REQUIRE_AUTH=true

# Only enable this for local development when you explicitly understand the risk.
BOT_API_ALLOW_INSECURE=false

# Disable the old legacy API in public mode. The structured API is the supported path.
LEGACY_BOT_ACTIONS_API_ENABLED=false

# ==============================
# Temporary migration-only global Discord IDs
# ==============================
# These are allowed as local/dev defaults only.
# Long-term public production must use DB-backed per-guild config.
TICKET_CATEGORY_ID=0
TICKET_ARCHIVE_CATEGORY_ID=0
TICKET_PREFIX=ticket
AUTO_DELETE_TICKET_SECONDS=0
TRANSCRIPTS_CHANNEL_ID=0
TRANSCRIPT_PANEL_NAME=Support
SINGLE_PANEL_MODE=true
JOIN_LOG_CHANNEL_ID=0

VERIFY_CHANNEL_ID=0
VC_VERIFY_CHANNEL_ID=0
VC_VERIFY_QUEUE_CHANNEL_ID=0
TOKEN_TTL_MINUTES=240
VC_REQUEST_TTL_MINUTES=240
VERIFY_KICK_HOURS=24
VC_REQUEST_COOLDOWN_SECONDS=60

UNVERIFIED_ROLE_ID=0
VERIFIED_ROLE_ID=0
RESIDENT_ROLE_ID=0
STONER_ROLE_ID=0
DRUNKEN_ROLE_ID=0
STAFF_ROLE_ID=0
VC_STAFF_ROLE_ID=0

MOD_TIMEOUT_MINUTES=60
MOD_ACTION_AUDIT_LOOKBACK_SECONDS=20
MODLOG_CHANNEL_ID=0
RAIDLOG_CHANNEL_ID=0
FORCE_VERIFY_LOG_CHANNEL_ID=0

# Temporary per-guild env overrides supported while DB-backed guild config is being completed.
# Prefer DB guild config after migration.
# Examples:
# MODLOG_CHANNEL_ID_123456789012345678=123456789012345678
# TRANSCRIPTS_CHANNEL_ID_123456789012345678=123456789012345678
# GUILD_123456789012345678_MODLOG_CHANNEL_ID=123456789012345678
# GUILD_123456789012345678_TRANSCRIPTS_CHANNEL_ID=123456789012345678

# ==============================
# Raid Detection
# ==============================
RAID_WINDOW_SECONDS=60
RAID_JOIN_THRESHOLD=6
RAID_LOCK_MINUTES=15
RAID_MASS_ROLE_STRIP=true

# ==============================
# Alt Detection
# ==============================
ALT_NEW_ACCOUNT_DAYS=7
ALT_CLUSTER_WINDOW_MINUTES=30
ALT_CLUSTER_MIN_GROUP=3

# ==============================
# Visual / Optional Roles
# ==============================
ENABLE_OPTIONAL_ROLE_PROMPT=true
OPTIONAL_ROLE_AUTO_CLOSE_SECONDS=0
VERIFY_EMBED_THUMBNAIL_URL=
ALLOW_USER_VERIFYLINK=false
VERIFY_TOKEN_TABLE=verification_tokens
TOKEN_TABLE=verification_tokens

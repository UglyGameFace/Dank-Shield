# Dank Shield public production .env example
# Never commit real tokens, Supabase service-role keys, API secrets, or customer data.
# Public rule: Discord server IDs belong in Supabase guild_configs via /dank setup, not here.

DEPLOYMENT_ENV=production
DANK_DEPLOYMENT_MODE=production
DANK_PUBLIC_MODE=true
DANK_PRODUCTION_MODE=true
DANK_COMMAND_PROFILE=public

# Public safety: keep deployment-level Discord IDs disabled.
DANK_ALLOW_SERVER_ENV_IDS=false
DANK_SERVER_ENV_IDS_ENABLED=false
DANK_PUBLIC_CONFIG_ISOLATION=true

# Slash command behavior
DANK_SYNC_BETA_GUILD_COMMANDS=false
CLEAR_GLOBAL_COMMANDS_ON_BOOT=false
DANK_DANGEROUS_CLEAR_ALL_GLOBAL_COMMANDS_ON_BOOT=false
DANK_SKIP_UNCHANGED_GLOBAL_SYNC=true
DANK_FORCE_COMMAND_SYNC_ON_BOOT=false
DANK_COMMAND_SYNC_STATE_FILE=.dank_command_sync_state.json
DANK_GUILD_COMMAND_CLEANUP_IDS=

# Compact production logs
DANK_COMMAND_LOG_STYLE=compact
DANK_STARTUP_LOG_STYLE=compact

# Public scale/runtime controls
DISCORD_AUTO_SHARD=true
DANK_EXPECTED_PUBLIC_GUILDS=100
DANK_RUNTIME_JOBS_MAX_CONCURRENT=8
DANK_STARTUP_MAX_GUILDS=50

# Per-guild config cache
DANK_GUILD_CONFIG_TABLE=guild_configs
DANK_GUILD_CONFIG_CACHE_TTL_SECONDS=60

# Public legal/support URLs - fill before wider public rollout
PUBLIC_BOT_TERMS_URL=
PUBLIC_BOT_PRIVACY_URL=
PUBLIC_BOT_SUPPORT_URL=
PUBLIC_BOT_DATA_REQUEST_URL=

# Retention/community defaults
TICKET_TRANSCRIPT_RETENTION_DAYS=90
MODLOG_RETENTION_DAYS=180
METRICS_RETENTION_DAYS=180
COMMUNITY_AGE_GATE_REQUIRED=false
COMMUNITY_MINIMUM_AGE=18

# Discord app secrets
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=

# Supabase REST API - service role is required for the bot runtime
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct/pooler Postgres DSN for schema bootstrap only.
# Leave blank on hosts that cannot reach Supabase direct IPv6. The bot can still run with REST above.
SUPABASE_DB_URL=
DATABASE_URL=

# Verification website / internal bot API
VERIFY_SITE_URL=
BOT_ACTIONS_API_URL=http://127.0.0.1:8081
BOT_API_SHARED_SECRET=
BOT_API_BIND_HOST=127.0.0.1
BOT_API_PORT=8081
BOT_API_REQUIRE_AUTH=true
BOT_API_ALLOW_INSECURE=false
LEGACY_BOT_ACTIONS_API_ENABLED=false

# Ticket defaults that are safe deployment-wide
TICKET_PREFIX=ticket
AUTO_DELETE_TICKET_SECONDS=0
TRANSCRIPT_PANEL_NAME=Support
SINGLE_PANEL_MODE=true
DANK_TICKET_CATEGORY_SOFT_LIMIT=49
DANK_TICKET_MAX_OVERFLOW_CATEGORIES=3
DANK_TICKET_OVERFLOW_AUTO_CREATE=true

# Verification timers
TOKEN_TTL_MINUTES=240
VC_REQUEST_TTL_MINUTES=240
VERIFY_KICK_HOURS=24
VC_REQUEST_COOLDOWN_SECONDS=60

# Moderation/raid/alt defaults
MOD_TIMEOUT_MINUTES=60
MOD_ACTION_AUDIT_LOOKBACK_SECONDS=20
RAID_WINDOW_SECONDS=60
RAID_JOIN_THRESHOLD=6
RAID_LOCK_MINUTES=15
RAID_MASS_ROLE_STRIP=true
ALT_NEW_ACCOUNT_DAYS=7
ALT_CLUSTER_WINDOW_MINUTES=30
ALT_CLUSTER_MIN_GROUP=3

# Optional role prompt / verification UI
ENABLE_OPTIONAL_ROLE_PROMPT=true
OPTIONAL_ROLE_AUTO_CLOSE_SECONDS=0
ALLOW_USER_VERIFYLINK=false
VERIFY_TOKEN_TABLE=verification_tokens
TOKEN_TABLE=verification_tokens

# Branding
BOT_DISPLAY_NAME=Dank Shield
VERIFY_UI_TITLE=Dank Shield Verification
DANK_SHIELD_TAGLINE_SHORT=Good vibes in. Bad actors out.
DANK_SHIELD_TAGLINE_LONG=Verification, tickets, and server protection without snuffing out the vibe.

# Intentionally omitted in public production:
# GUILD_ID, *_CHANNEL_ID, *_CATEGORY_ID, *_ROLE_ID, DANK_TICKET_OVERFLOW_CATEGORY_IDS
# Configure those per server with /dank setup so one server can never inherit another server's IDs.
